<!DOCTYPE html>
<html>
<head>
  <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background-color: #007bff; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background-color: #f8f9fa; }
    .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
    .announcement-title { font-size: 24px; font-weight: bold; margin-bottom: 15px; }
    .announcement-content { margin-bottom: 20px; }
    .meta { color: #666; font-size: 14px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>New Score</h1>
    </div>
    
    <div class="content">
      <div class="announcement-title">
        <%= @score_type %>
      </div>
      
      <div class="announcement-content">
        A new <%= @score_type %> has been posted on the platform.
        Kindly check the platform for more details.
        <%= link_to 'cla.jjrsf.org', 'https://cla.jjrsf.org' %>
      </div>
      
      <div class="meta">
        <p><strong>Posted:</strong> <%= @score.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        <% if @score.cla_cohort %>
          <p><strong>Cohort:</strong> <%= @score.cla_cohort.name %></p>
        <% end %>
      </div>
    </div>
    
    <div class="footer">
      <p>This is a notification from JJRSF Christian Leadership Academy.</p>
    </div>
  </div>
</body>
</html> 